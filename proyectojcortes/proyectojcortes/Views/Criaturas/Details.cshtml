@model proyectojcortes.Models.Criatura

@{
    ViewData["Title"] = "Details";
}

<h1>Details</h1>

<div>
    <h4>Criatura</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Nombre)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Nombre)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Categoria)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Categoria)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Bioma)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Bioma)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RarezaBase)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RarezaBase)
        </dd>
    </dl>
</div>

<div class="mt-3">
    <form asp-action="MarcarComoDerrotado" method="post">
        <input type="hidden" name="criaturaId" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Marcar como Derrotado</button>
    </form>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.Id">Edit</a> |
    <a asp-action="Index">Back to List</a>
</div>